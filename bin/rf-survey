#!/usr/bin/env bash
# rf-survey — CLI för att hantera RF-Site-Survey via pm2
# Auto-detekterar installationskatalog genom att följa symlinks

set -euo pipefail

# Färger
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

# Resolve symlinks och hitta projektets rotkatalog
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
APP_DIR="$(cd -P "$(dirname "$SOURCE")/.." && pwd)"

APP_NAME="rf-site-survey"
ECOSYSTEM="$APP_DIR/ecosystem.config.cjs"

# Kontrollera att pm2 finns installerat
check_pm2() {
  if ! command -v pm2 &>/dev/null; then
    echo -e "${RED}Error: pm2 is not installed.${NC}"
    echo -e "Install it with: ${CYAN}npm install -g pm2${NC}"
    exit 1
  fi
}

# Kontrollera att ecosystem-filen finns
check_ecosystem() {
  if [ ! -f "$ECOSYSTEM" ]; then
    echo -e "${RED}Error: ecosystem.config.cjs not found at $ECOSYSTEM${NC}"
    exit 1
  fi
}

# Kontrollera att .next build finns
check_build() {
  if [ ! -d "$APP_DIR/.next" ]; then
    echo -e "${YELLOW}No production build found. Building now...${NC}"
    cd "$APP_DIR"
    npm run build
  fi
}

cmd_start() {
  check_pm2
  check_ecosystem
  check_build
  echo -e "${CYAN}Starting $APP_NAME...${NC}"
  pm2 delete "$APP_NAME" 2>/dev/null || true
  pm2 start "$ECOSYSTEM"
  echo -e "${GREEN}$APP_NAME started.${NC}"
}

cmd_stop() {
  check_pm2
  echo -e "${CYAN}Stopping $APP_NAME...${NC}"
  pm2 stop "$APP_NAME"
  echo -e "${GREEN}$APP_NAME stopped.${NC}"
}

cmd_restart() {
  check_pm2
  echo -e "${CYAN}Restarting $APP_NAME...${NC}"
  pm2 restart "$APP_NAME"
  echo -e "${GREEN}$APP_NAME restarted.${NC}"
}

cmd_status() {
  check_pm2
  pm2 status "$APP_NAME"
}

cmd_logs() {
  check_pm2
  shift_args="${@:2}"
  pm2 logs "$APP_NAME" $shift_args
}

cmd_update() {
  check_pm2
  cd "$APP_DIR"

  OLD_COMMIT=$(git rev-parse --short HEAD 2>/dev/null || echo "unknown")
  echo -e "${CYAN}Current commit: ${BOLD}$OLD_COMMIT${NC}"

  echo -e "${CYAN}Pulling latest changes...${NC}"
  git pull

  NEW_COMMIT=$(git rev-parse --short HEAD 2>/dev/null || echo "unknown")
  echo -e "${CYAN}New commit: ${BOLD}$NEW_COMMIT${NC}"

  if [ "$OLD_COMMIT" = "$NEW_COMMIT" ]; then
    echo -e "${YELLOW}Already up to date.${NC}"
  else
    echo -e "${GREEN}Updated from $OLD_COMMIT to $NEW_COMMIT.${NC}"
  fi

  echo -e "${CYAN}Installing dependencies...${NC}"
  npm install

  echo -e "${CYAN}Building...${NC}"
  npm run build

  echo -e "${CYAN}Restarting $APP_NAME...${NC}"
  pm2 restart "$APP_NAME"

  echo -e "${GREEN}Update complete.${NC}"
}

cmd_setup() {
  check_pm2
  check_ecosystem
  cd "$APP_DIR"

  echo -e "${CYAN}Installing dependencies...${NC}"
  npm install

  echo -e "${CYAN}Building application...${NC}"
  npm run build

  echo -e "${CYAN}Starting $APP_NAME with pm2...${NC}"
  pm2 start "$ECOSYSTEM"

  echo -e "${CYAN}Saving pm2 process list...${NC}"
  pm2 save

  echo -e "${CYAN}Generating startup script...${NC}"
  echo -e "${YELLOW}Run the following command as root to enable auto-start on boot:${NC}"
  pm2 startup

  echo -e "${GREEN}Setup complete. $APP_NAME is running on port 3000.${NC}"
}

cmd_help() {
  echo -e "${BOLD}rf-survey${NC} — CLI for managing RF-Site-Survey"
  echo ""
  echo -e "${BOLD}Usage:${NC} rf-survey <command>"
  echo ""
  echo -e "${BOLD}Commands:${NC}"
  echo -e "  ${CYAN}start${NC}     Start the application"
  echo -e "  ${CYAN}stop${NC}      Stop the application"
  echo -e "  ${CYAN}restart${NC}   Restart the application"
  echo -e "  ${CYAN}status${NC}    Show application status"
  echo -e "  ${CYAN}update${NC}    Pull latest code, rebuild, and restart"
  echo -e "  ${CYAN}logs${NC}      Show application logs (follow mode, pass --lines N for history)"
  echo -e "  ${CYAN}setup${NC}     Initial setup: install, build, start, enable boot"
  echo -e "  ${CYAN}help${NC}      Show this help message"
  echo ""
  echo -e "${BOLD}App directory:${NC} $APP_DIR"
}

case "${1:-help}" in
  start)   cmd_start ;;
  stop)    cmd_stop ;;
  restart) cmd_restart ;;
  status)  cmd_status ;;
  update)  cmd_update ;;
  logs)    cmd_logs "$@" ;;
  setup)   cmd_setup ;;
  help|--help|-h) cmd_help ;;
  *)
    echo -e "${RED}Unknown command: $1${NC}"
    cmd_help
    exit 1
    ;;
esac
